<!DOCTYPE html>
<html>
<head>
    <title>College Registration Form</title>
</head>
<body>

    <h2 align="center">Arts and Science College Registration Form</h2>

    <form>

        <label>Student Name:</label>
        <input type="text" name="name"><br><br>

        <label>Date of Birth:</label>
        <input type="date" name="dob"><br><br>

        <label>Gender:</label>
        <input type="radio" name="gender"> Male
        <input type="radio" name="gender"> Female
        <input type="radio" name="gender"> Other
        <br><br>

        <label>Email ID:</label>
        <input type="email" name="email"><br><br>

        <label>Mobile Number:</label>
        <input type="tel" name="mobile"><br><br>

        <label>Address:</label><br>
        <textarea rows="4" cols="30"></textarea>
        <br><br>

        <label>Department:</label>
        <select>
            <option>Computer Science</option>
            <option>Mathematics</option>
            <option>Physics</option>
            <option>Chemistry</option>
            <option>English</option>
            <option>Commerce</option>
        </select>
        <br><br>

        <label>Admission Program:</label><br>
        <input type="radio" name="course"> UG
        <input type="radio" name="course"> PG
        <input type="radio" name="course"> PhD
        <br><br>

        <label>Languages Known:</label><br>
        <input type="checkbox"> Tamil
        <input type="checkbox"> English
        <input type="checkbox"> Hindi
        <br><br>

        <label>Upload Mark Sheet:</label>
        <input type="file">
        <br><br>

        <input type="submit" value="Register">
        <input type="reset" value="Clear">

    </form>

</body>
</html>
