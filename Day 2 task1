<!DOCTYPE html>
<html>
<head>
    <title>School Time Table</title>
</head>
<body>

<h2 align="center">School Time Table</h2>

<table border="1" cellspacing="0" cellpadding="5" align="center">
    <tr>
        <th>Day</th>
        <th>I</th>
        <th>II</th>
        <th>Break</th>
        <th>III</th>
        <th>IV</th>
        <th>Lunch</th>
        <th>V</th>
        <th>VI</th>
        <th>Break</th>
        <th>VII</th>
        <th>VIII</th>
    </tr>

    <tr>
        <th>Monday</th>
        <td>Math</td>
        <td>English</td>
        <td rowspan="6">BREAK</td>
        <td>Science</td>
        <td>Social</td>
        <td rowspan="6">LUNCH</td>
        <td>Computer</td>
        <td>Physics</td>
        <td rowspan="6">BREAK</td>
        <td>Drawing</td>
        <td>Sports</td>
    </tr>

    <tr>
        <th>Tuesday</th>
        <td>Tamil</td>
        <td>English</td>
        <td>Math</td>
        <td>Biology</td>
        <td>History</td>
        <td>Computer</td>
        <td>Library</td>
        <td>Games</td>
    </tr>

    <tr>
        <th>Wednesday</th>
        <td>Physics</td>
        <td>Chemistry</td>
        <td>Math</td>
        <td>English</td>
        <td>Lab Session</td>
        <td colspan="2">Lab</td>
        <td>Social</td>
        <td>PT</td>
    </tr>

    <tr>
        <th>Thursday</th>
        <td colspan="2">Project Work</td>
        <td>History</td>
        <td>Geography</td>
        <td>Math</td>
        <td>English</td>
        <td>Activity</td>
        <td>Sports</td>
    </tr>

    <tr>
        <th>Friday</th>
        <td>Math</td>
        <td>English</td>
        <td>Physics</td>
        <td>Chemistry</td>
        <td>Biology</td>
        <td>Computer</td>
        <td>Sports</td>
        <td>Library</td>
    </tr>

    <tr>
        <th>Saturday</th>
        <td>Math</td>
        <td>English</td>
        <td>Science</td>
        <td>Activity</td>
        <td>Games</td>
        <td>PT</td>
        <td colspan="2">Extra Class</td>
    </tr>

</table>

</body>
</html>
