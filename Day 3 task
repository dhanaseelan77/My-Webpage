<button class="small-btn">Learn More</button>
</div>
</div>

<div class="solution">
<img src="https://images.unsplash.com/photo-1611974789855-9c2a0a7236a3">
<div class="content">
<h3>Investment Management</h3>
<p>Professional investment services for growth.</p>
<button class="small-btn">Learn More</button>
</div>
</div>

<div class="solution">
<img src="https://images.unsplash.com/photo-1560518883-ce09059eeffa">
<div class="content">
<h3>Wealth Management</h3>
<p>Comprehensive solutions for wealth creation.</p>
<button class="small-btn">Learn More</button>
</div>
</div>

</div>
</section>

