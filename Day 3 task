<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Prosperum Landing Page</title>

<style>
*{
    margin:0;
    padding:0;
    box-sizing:border-box;
    font-family: 'Segoe UI', sans-serif;
}

body{
    background:#f5f5f5;
}

/* HEADER */
header{
    background:#0f2347;
    color:white;
    padding:20px 8%;
    display:flex;
    justify-content:space-between;
    align-items:center;
}

.logo{
    font-size:30px;
    font-weight:bold;
}

nav ul{
    list-style:none;
    display:flex;
    gap:30px;
}

nav a{
    text-decoration:none;
    color:white;
}

.btn{
    background:#c89b4d;
    color:white;
    padding:10px 20px;
    border:none;
    border-radius:5px;
    cursor:pointer;
}

/* HERO */
.hero{
    background:linear-gradient(rgba(15,35,71,0.85),
    rgba(15,35,71,0.85)),
    url('https://images.unsplash.com/photo-1460925895917-afdab827c52f');
    background-size:cover;
    background-position:center;
    color:white;
    padding:120px 8%;
}

.hero h1{
    font-size:60px;
    max-width:600px;
    margin-bottom:20px;
}

.hero p{
    max-width:500px;
    margin-bottom:25px;
    line-height:1.6;
}

/* TOP CARDS */
.cards{
    display:flex;
    justify-content:center;
    gap:25px;
    flex-wrap:wrap;
    margin-top:-50px;
    padding:0 8%;
}

.card{
    background:white;
    width:320px;
    padding:25px;
    border-radius:10px;
    box-shadow:0 5px 15px rgba(0,0,0,0.1);
}

.card h3{
    margin-bottom:10px;
}

.card p{
    color:#666;
    margin-bottom:15px;
}

.small-btn{
    background:#c89b4d;
    color:white;
    border:none;
    padding:8px 15px;
    border-radius:5px;
}

/* SOLUTIONS */
.solutions{
    padding:80px 8%;
}

.solutions h2{
    text-align:center;
    margin-bottom:40px;
    font-size:40px;
}

.grid{
    display:grid;
    grid-template-columns:repeat(auto-fit,minmax(300px,1fr));
    gap:25px;
}

.solution{
    background:white;
    border-radius:10px;
    overflow:hidden;
    box-shadow:0 5px 15px rgba(0,0,0,0.1);
}

.solution img{
    width:100%;
    height:220px;
    object-fit:cover;
}

.content{
    padding:20px;
}

.content h3{
    margin-bottom:10px;
}

.content p{
    color:#666;
    margin-bottom:15px;
}

/* HOW WE WORK */
.work{
    background:white;
    padding:70px 8%;
}

.work h2{
    text-align:center;
    margin-bottom:50px;
}

.steps{
    display:flex;
    justify-content:space-around;
    flex-wrap:wrap;
    gap:20px;
}

.step{
    text-align:center;
    max-width:250px;
}

.circle{
    width:70px;
    height:70px;
    border-radius:50%;
    background:#c89b4d;
    color:white;
    display:flex;
    justify-content:center;
    align-items:center;
    margin:auto;
    font-size:25px;
    margin-bottom:15px;
}

/* CONSULTATION */
.consult{
    background:#0f2347;
    color:white;
    padding:70px 8%;
}

.consult-container{
    display:flex;
    gap:40px;
    justify-content:space-between;
    flex-wrap:wrap;
}

.form{
    flex:1;
}

.form input,
.form textarea{
    width:100%;
    padding:12px;
    margin-bottom:15px;
    border:none;
    border-radius:5px;
}

.form button{
    background:#c89b4d;
    color:white;
    border:none;
    padding:12px 20px;
    border-radius:5px;
}

footer{
    background:#08162f;
    color:white;
    text-align:center;
    padding:20px;
}

@media(max-width:768px){

header{
    flex-direction:column;
    gap:15px;
}

nav ul{
    flex-wrap:wrap;
    justify-content:center;
}

.hero h1{
    font-size:40px;
}

.consult-container{
    flex-direction:column;
}
}
</style>
</head>

<body>

<header>
    <div class="logo">PROSPERUM</div>

    <nav>
        <ul>
